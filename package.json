{
  "name": "classroom-jeopardy",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply jeopardy-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply jeopardy-db --remote",
    "cf:dev": "wrangler pages dev",
    "cf:deploy:do": "wrangler deploy --config wrangler.worker.json",
    "cf:deploy:pages": "wrangler pages deploy",
    "cf:deploy": "npm run cf:deploy:do && npm run cf:deploy:pages"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@sveltejs/adapter-cloudflare": "^4.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.22",
    "drizzle-kit": "^0.30.0",
    "postcss": "^8.5.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wrangler": "^4.73.0"
  },
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.0",
    "qrcode": "^1.5.4"
  }
}
